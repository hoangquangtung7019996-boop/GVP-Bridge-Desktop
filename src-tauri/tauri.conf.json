{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GVP Bridge",
  "version": "0.1.0",
  "identifier": "com.gvp.bridge",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "GVP Bridge",
        "width": 500,
        "height": 650,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
