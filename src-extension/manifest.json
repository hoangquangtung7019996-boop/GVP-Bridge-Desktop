{
  "manifest_version": 3,
  "name": "GVP Bridge",
  "version": "0.1.0",
  "description": "Bridge extension for GVP Desktop - connects to desktop app via WebSocket",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://*.x.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/i/grok*",
        "https://*.x.com/i/grok*"
      ],
      "js": [
        "selectors.js",
        "ws-client.js",
        "dom-ops.js",
        "content.js"
      ],
      "type": "module"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
